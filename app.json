{
  "expo": {
    "name": "AR Space Placer",
    "slug": "viro-ar-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.viroarapp",
      "newArchEnabled": false,
      "infoPlist": {
        "NSCameraUsageDescription": "This app requires camera access to scan physical surfaces and place virtual 3D objects in the room."
      }
    },
    "android": {
      "package": "com.anonymous.viroarapp",
      "newArchEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "@reactvision/react-viro",
        {
          "androidCpuFilters": ["arm64-v8a"]
        }
      ]
    ]
  }
}
